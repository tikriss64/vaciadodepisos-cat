Redirect 301 /avís-legal-ca.html https://vaciadodepisos.cat/avis-legal-ca.html
# ============================================================
# REDIRECCIONES AÑADIDAS PARA RESOLVER 404 PENDIENTES
# ============================================================

# URL truncada: /limpieza-sindrome- → redirige a la página completa
RedirectMatch 301 ^/limpieza-sindrome-?$ https://vaciadodepisos.cat/limpieza-sindrome-diogenes-barcelona-protocolo.html

# URLs basura con caracteres extraños (<, >) devolver 410 Gone para que Google las olvide
RedirectMatch 410 ^/.*[<>].*$

# NOTA: Se eliminó la regla que hacía 301 borrando utm_/fbclid/gclid/msclkid.
# Esa regla destruía el tracking de campañas en Analytics (todo el tráfico
# de pago, email y redes aparecía como "Directo"). Los parámetros de campaña
# deben conservarse; Google los ignora para indexación gracias al canonical.

RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif)$ no-gzip dont-vary
    SetEnvIfNoCase Request_URI \.(?:mp4|webm|ogg)$ no-gzip dont-vary
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 6 months"
    ExpiresByType text/javascript "access plus 6 months"
    ExpiresByType application/javascript "access plus 6 months"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2?|ttf|eot|svg|png|jpe?g|gif|webp|avif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header unset ETag
        FileETag None
    </FilesMatch>
    
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS: fuerza HTTPS a nivel de navegador (refuerza la señal HTTPS de Google).
    # Seguro: el sitio ya redirige todo a HTTPS (regla de arriba). Sin 'preload'
    # para no comprometerse con la lista de precarga (requiere todos los subdominios en HTTPS).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
	# ---- CANONICAL PARA PDFs ----
<Files "02_checklist_limpieza_es.pdf">
    Header set Link '<https://vaciadodepisos.cat/imagenes/pdf/02_checklist_limpieza_es.pdf>; rel="canonical"'
    Header append Link '<https://vaciadodepisos.cat/imagenes/pdf/02_checklist_neteja_ca.pdf>; rel="alternate"; hreflang="ca"'
</Files>
