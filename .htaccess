RewriteRule ^gràcies\.html$ /gracies.html [R=301,L]
Options +FollowSymLinks -MultiViews

RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

RedirectMatch 301 ^/(.+)\.html\.html$ https://vaciadodepisos.cat/$1.html
