    Header append Link '<https://vaciadodepisos.cat/imagenes/pdf/01_guia_colaboradores_es.pdf>; rel="alternate"; hreflang="es"'
</Files>
</IfModule>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_mime.c>
    AddType image/avif avif
</IfModule>